rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users Collection
    // Read: All authenticated users can read basic profiles (names/avatars for UI)
    // Write: User can create/edit own profile, Admins can edit any
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId && request.resource.data.role == 'employee';
      allow update: if isAuthenticated() &&
        (isAdmin() || 
        (request.auth.uid == userId && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))));
      allow delete: if isAdmin();
    }

    // Tasks Collection
    match /tasks/{taskId} {
      // Read: Admin can read all. Employee can read if they are assigned or if they created it.
      allow read: if isAuthenticated() && 
        (isAdmin() || 
         (resource.data.assignedTo != null && request.auth.uid in resource.data.assignedTo) ||
         resource.data.createdBy == request.auth.uid);
         
      // Create: Admin can create any. Employee can create personal tasks (!isAdminTask).
      allow create: if isAuthenticated() && 
        (isAdmin() || 
         (request.resource.data.isAdminTask == false && request.resource.data.createdBy == request.auth.uid));
         
      // Update: Admin can update any. Employee can update progress/status/dueDate of assigned tasks, or fully edit self-created tasks.
      allow update: if isAuthenticated() && 
        (isAdmin() || 
         (resource.data.isAdminTask == false && resource.data.createdBy == request.auth.uid) ||
         (resource.data.assignedTo != null && request.auth.uid in resource.data.assignedTo && 
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['title', 'description', 'assignedTo', 'startDate', 'priority', 'module', 'isAdminTask'])));

      // Delete: Admin can delete any. Employee can delete self-created tasks.
      allow delete: if isAuthenticated() &&
        (isAdmin() || 
         (resource.data.isAdminTask == false && resource.data.createdBy == request.auth.uid));
    }

    // Announcements Collection
    match /announcements/{announcementId} {
      // Read: All authenticated users can read. (Filters applied in client UI)
      allow read: if isAuthenticated();
      
      // Mark as read (Update isRead array): Any authenticated user can append their uid
      allow update: if isAuthenticated() && 
        (isAdmin() || 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']));

      // Create/Delete: Admins only
      allow create, delete: if isAdmin();
    }

    // Notifications Collection
    match /notifications/{userId}/items/{notificationId} {
      // Any authenticated user can CREATE a notification for anyone (needed for client-side cross-user notifications)
      allow create: if isAuthenticated();
      // Only the notification owner can read, update (mark read), or delete their own notifications
      allow read, update, delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // Leave Management Collection
    // Schema: leaves/{leaveId}
    // { uid, applicantName, type, startDate, endDate, reason, status, createdAt, reviewedBy? }
    match /leaves/{leaveId} {
      // Read: owner can read own; admin can read all (for pending approvals view)
      allow read: if isAuthenticated() &&
        (resource.data.uid == request.auth.uid || isAdmin());

      // Create: any authenticated user can apply for their own leave
      allow create: if isAuthenticated() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.status == 'pending';

      // Update: only admins can change status (approve / reject)
      allow update: if isAdmin();

      // Delete: admins only
      allow delete: if isAdmin();
    }

    // Attendance Collection
    // Schema: attendance/{uid}/records/{recordId}
    // Each user owns their own attendance sub-collection.
    // Admins can read any user's records (e.g., for manager dashboards).
    // Users can only read/write their own records.
    match /attendance/{userId}/records/{recordId} {
      // Read: own records always; admin can read anyone's
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId || isAdmin());

      // Create: only the owner can punch in (create a new record for themselves)
      allow create: if isAuthenticated() && request.auth.uid == userId;

      // Update: only the owner can punch out (update their own open record)
      allow update: if isAuthenticated() && request.auth.uid == userId;

      // Delete: admins only (e.g., correcting erroneous records)
      allow delete: if isAdmin();
    }

    // Recruitment — Candidates Collection
    // Schema: candidates/{candidateId}
    // { name, email, role, experience, status, notes, createdAt, updatedAt }
    match /candidates/{candidateId} {
      // All authenticated users can view the recruitment pipeline
      allow read: if isAuthenticated();

      // Only admins can add candidates or move them between columns
      allow create, update: if isAdmin();

      // Delete: admins only
      allow delete: if isAdmin();
    }

    // Performance Reviews Collection
    // Schema: performances/{reviewId}
    // { uid, employeeName, reviewedBy, period, skills{...}, goalsAssigned, goalsCompleted, notes, createdAt }
    match /performances/{reviewId} {
      // Employee can read their own reviews; admins can read all
      allow read: if isAuthenticated() &&
        (resource.data.uid == request.auth.uid || isAdmin());

      // Only admins can create or update reviews
      allow create, update: if isAdmin();

      // Delete: admins only
      allow delete: if isAdmin();
    }
  }
}
