rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Returns true only if the signed-in user's email exists in the allowed_emails
    // whitelist collection AND the document has status 'approved' (or no status field).
    // CR-4 fix: checking status allows admins to suspend a user by setting status:'suspended'
    // without having to delete the document entirely.
    function isEmailAllowed() {
      let ref = /databases/$(database)/documents/allowed_emails/$(request.auth.token.email);
      return exists(ref)
        && get(ref).data.get('status', 'approved') == 'approved';
    }

    // Resolves secondary emails to their primary UID via user_email_map.
    // If the logged-in email is in the map, returns the primaryUid; otherwise
    // returns the Firebase Auth UID unchanged. This makes secondary-account
    // logins transparently identical to primary-account logins in rules.
    function getEffectiveUid() {
      let email = request.auth.token.email;
      return exists(/databases/$(database)/documents/user_email_map/$(email))
        ? get(/databases/$(database)/documents/user_email_map/$(email)).data.primaryUid
        : request.auth.uid;
    }

    function isAdmin() {
      let uid = getEffectiveUid();
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(uid))
        && get(/databases/$(database)/documents/users/$(uid)).data.get('role', '') == 'admin';
    }

    function isTaskParticipantLocal(taskData) {
      let uid = getEffectiveUid();
      let assigned = taskData.get('assignedTo', []);
      let isAssignee = (assigned is string && assigned == uid) || (assigned is list && uid in assigned);
      return isAdmin() ||
             taskData.get('createdBy', '') == uid ||
             isAssignee ||
             (uid in taskData.get('workPartnerUids', []));
    }


    function isTaskParticipant(taskId) {
      return isTaskParticipantLocal(get(/databases/$(database)/documents/tasks/$(taskId)).data);
    }

    // ── Whitelist / Allowed Emails Collection ───────────────────────────────
    // Document ID == email address. Existence + status == 'approved' = access granted.
    // Read:  CR-5 fix: restricted to own email only. Each user can check only their own
    //        whitelist document — prevents enumeration of the full employee list.
    //        NOTE: isEmailAllowed() internally uses exists()/get() which are always
    //        evaluated by the Rules engine regardless of this read rule — no circular dep.
    // Write: Admins only — only the admin can invite or revoke access.
    match /allowed_emails/{emailId} {
      allow read: if isAuthenticated() && emailId == request.auth.token.email;
      allow write: if isAdmin();
    }

    // Users Collection
    // Read:   Any whitelisted authenticated user can read profiles (needed for Team Members grid)
    // Create: First-time Google login creates own profile with role = 'employee' only
    // Update: User can update their own SAFE personal fields only;
    //         Admin can update any user's full profile
    // Delete: Admins only
    match /users/{userId} {
      allow read: if isAuthenticated() && isEmailAllowed();

      allow create: if isAuthenticated() && isEmailAllowed()
        && request.auth.uid == userId
        && request.resource.data.role == 'employee'
        // Block secondary emails from creating new user docs —
        // they are handled by AuthContext's email-map redirect
        && !exists(/databases/$(database)/documents/user_email_map/$(request.auth.token.email));

      allow update: if isAuthenticated() && isEmailAllowed() && (
        isAdmin()
        || (
          getEffectiveUid() == userId
          && !request.resource.data.diff(resource.data)
              .affectedKeys()
              .hasAny(['role', 'uid', 'email', 'salaryBase', 'department', 'designation', 'fcmToken'])
        )
      );

      allow delete: if isAdmin();
    }

    // Email → Primary UID Lookup Map
    // Read:   ME-9 + CR-5 fix: restricted to own email only. Each user can resolve only
    //         their own secondary-email → primary-UID mapping on login. This prevents a
    //         non-whitelisted Google account from reading anyone else's email mappings.
    // Write:  Admin only — prevents malicious email re-routing
    match /user_email_map/{emailId} {
      allow read: if isAuthenticated() && emailId == request.auth.token.email;
      allow write: if isAdmin();
    }

    // Tasks Collection
    //
    // Field schema additions (never remove existing fields):
    //   workPartners:    array of { uid, name, avatar, addedBy, addedByName, addedAt }
    //                    Rich object array — read by UI components only.
    //   workPartnerUids: string[]  — parallel flat array of UIDs extracted from workPartners.
    //                    ONLY used for Firestore security rules (rules cannot query into
    //                    array-of-maps). Always updated atomically with workPartners in the
    //                    same updateDoc call via arrayUnion/arrayRemove. See taskService.js.
    match /tasks/{taskId} {

      // Read: Admin sees all. Employee sees tasks they are assigned to, created, or partnered on.
      allow read: if isAuthenticated() && isEmailAllowed() && (
        isAdmin() ||
        ('assignedTo' in resource.data && getEffectiveUid() in resource.data.assignedTo) ||
        ('createdBy' in resource.data && resource.data.createdBy == getEffectiveUid()) ||
        ('workPartnerUids' in resource.data && getEffectiveUid() in resource.data.workPartnerUids)
      );

      // Create: Admin can create any. Employee can create personal tasks (isAdminTask == false/undefined).
      allow create: if isAuthenticated() && isEmailAllowed() && (
        isAdmin() ||
        (request.resource.data.get('isAdminTask', false) == false && request.resource.data.get('createdBy', '') == getEffectiveUid())
      );

      // Update: Admin can update any.
      // 1. Creator can update personal tasks.
      // 2. Assignee can update progress/status/dueDate/completionNote/attachments (denied from core metadata).
      // 3. ANY participant (Creator, Assignee, Work Partner) can update the workPartner arrays + updatedAt.
      allow update: if isAuthenticated() && isEmailAllowed() && (
        isAdmin() ||
        (resource.data.get('isAdminTask', false) == false && resource.data.get('createdBy', '') == getEffectiveUid()) ||
        (
          ('assignedTo' in resource.data) &&
          ((resource.data.assignedTo is string && resource.data.assignedTo == getEffectiveUid()) || 
           (resource.data.assignedTo is list && getEffectiveUid() in resource.data.assignedTo)) &&
          !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['title', 'description', 'assignedTo', 'startDate', 'priority', 'module', 'isAdminTask'])
        ) ||
        (
          isTaskParticipantLocal(resource.data) &&
          request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['workPartners', 'workPartnerUids', 'updatedAt'])
        )
      );

      // Delete: Admin can delete any. Employee can delete own personal tasks.
      allow delete: if isAuthenticated() && isEmailAllowed() && (
        isAdmin() ||
        (resource.data.get('isAdminTask', false) == false && resource.data.get('createdBy', '') == getEffectiveUid())
      );

      // ── Timeline Events Subcollection ────────────────────────────────────────
      // Schema: tasks/{taskId}/events/{eventId}
      // {
      //   type:         "partner_added" | "status_changed" | "progress_updated" | "commit"
      //   authorUid:    string   — UID of the triggering user
      //   authorName:   string   — denormalized display name
      //   authorAvatar: string   — denormalized avatar URL
      //   message:      string   — human-readable description
      //   metadata:     object   — type-specific extra data (see taskService.js for shapes)
      //   createdAt:    Timestamp — server timestamp; used for ordering (sorted client-side)
      // }
      match /events/{eventId} {

        // Read: Anyone who can read the parent task can read its events.
        allow read: if isAuthenticated() && isEmailAllowed() && isTaskParticipant(taskId);

        // Create: Only task participants (assignees, creator, work partners, admin) can post events.
        // authorUid must equal the requesting user — no spoofing.
        allow create: if isAuthenticated() && isEmailAllowed() && isTaskParticipant(taskId) && request.resource.data.authorUid == getEffectiveUid();

        // Update / Delete: Only the event author or an admin can modify or delete an event.
        allow update, delete: if isAuthenticated() && isEmailAllowed() && (
          isAdmin() ||
          resource.data.authorUid == getEffectiveUid()
        );
      }
    }

    // Announcements Collection
    match /announcements/{announcementId} {
      // Read: All whitelisted authenticated users can read. (Filters applied in client UI)
      allow read: if isAuthenticated() && isEmailAllowed();
      
      // Mark as read (Update isRead array): Any whitelisted authenticated user can append their uid
      allow update: if isAuthenticated() && isEmailAllowed() && 
        (isAdmin() || 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']));

      // Create/Delete: Admins only
      allow create, delete: if isAdmin();
    }

    // Notifications Collection
    // CR-6 fix: restricted notification creation to prevent phishing/spam attacks.
    // A whitelisted user may notify others ONLY IF:
    //   1. senderUid in the payload equals their own effective UID (no impersonation)
    //   2. read field is false (notifications are always unread on creation)
    //   3. type is one of the known application enum values
    //   4. title and message are within reasonable length limits
    match /notifications/{userId}/items/{notificationId} {
      allow create: if isAuthenticated() && isEmailAllowed()
        && request.resource.data.get('senderUid', '') == getEffectiveUid()
        && request.resource.data.get('read', true) == false
        && request.resource.data.get('type', '') in [
             'task_assigned', 'task_updated', 'task_completed',
             'announcement', 'partner_added', 'general'
           ]
        && request.resource.data.get('title', '').size() <= 200
        && request.resource.data.get('message', '').size() <= 500;
      // Only the notification owner can read, update (mark read), or delete their own notifications
      allow read, update, delete: if isAuthenticated() && isEmailAllowed()
        && (getEffectiveUid() == userId || request.auth.uid == userId);
    }

    // Leave Management Collection
    // Schema: leaves/{leaveId}
    // { uid, applicantName, type, startDate, endDate, reason, status, createdAt, reviewedBy? }
    match /leaves/{leaveId} {
      // Read: owner can read own; admin can read all (for pending approvals view)
      allow read: if isAuthenticated() && isEmailAllowed() &&
        (resource.data.uid == getEffectiveUid() || isAdmin());

      // Create: any whitelisted authenticated user can apply for their own leave
      allow create: if isAuthenticated() && isEmailAllowed() &&
        request.resource.data.uid == getEffectiveUid() &&
        request.resource.data.status == 'pending';

      // Update: only admins can change status (approve / reject)
      allow update: if isAdmin();

      // Delete: admins only
      allow delete: if isAdmin();
    }

    // Attendance Collection
    // Schema: attendance/{uid}/records/{recordId}
    // Each user owns their own attendance sub-collection.
    // Admins can read any user's records (e.g., for manager dashboards).
    // Users can only read/write their own records.
    match /attendance/{userId}/records/{recordId} {
      // Read: own records always; admin can read anyone's
      allow read: if isAuthenticated() && isEmailAllowed() &&
        (getEffectiveUid() == userId || isAdmin());

      // Create: only the owner can punch in (create a new record for themselves)
      allow create: if isAuthenticated() && isEmailAllowed() && getEffectiveUid() == userId;

      // Update: only the owner can punch out (update their own open record)
      allow update: if isAuthenticated() && isEmailAllowed() && getEffectiveUid() == userId;

      // Delete: admins only (e.g., correcting erroneous records)
      allow delete: if isAdmin();
    }

    // Recruitment — Candidates Collection
    // Schema: candidates/{candidateId}
    // { name, email, role, experience, status, notes, createdAt, updatedAt }
    match /candidates/{candidateId} {
      // All whitelisted authenticated users can view the recruitment pipeline
      allow read: if isAuthenticated() && isEmailAllowed();

      // Only admins can add candidates or move them between columns
      allow create, update: if isAdmin();

      // Delete: admins only
      allow delete: if isAdmin();
    }

    // Performance Reviews Collection
    // Schema: performances/{reviewId}
    // { uid, employeeName, reviewedBy, period, skills{...}, goalsAssigned, goalsCompleted, notes, createdAt }
    match /performances/{reviewId} {
      // Employee can read their own reviews; admins can read all
      allow read: if isAuthenticated() && isEmailAllowed() &&
        (resource.data.uid == getEffectiveUid() || isAdmin());

      // Only admins can create or update reviews
      allow create, update: if isAdmin();

      // Delete: admins only
      allow delete: if isAdmin();
    }

    // ── KPI Collections ────────────────────────────────────────────────────────
    // All KPI collections follow the same admin-write / all-read pattern:
    //   Read:          Any whitelisted authenticated user can view KPI data.
    //   Create/Update: Admins only — admins manage all KPI entries via the UI.
    //   Delete:        Admins only.

    match /kpi_industries/{docId} {
      allow read:           if isAuthenticated() && isEmailAllowed();
      allow create, update: if isAdmin();
      allow delete:         if isAdmin();
    }

    match /kpi_clients/{docId} {
      allow read:           if isAuthenticated() && isEmailAllowed();
      allow create, update: if isAdmin();
      allow delete:         if isAdmin();
    }

    match /kpi_products/{docId} {
      allow read:           if isAuthenticated() && isEmailAllowed();
      allow create, update: if isAdmin();
      allow delete:         if isAdmin();
    }

    match /kpi_sales/{docId} {
      allow read:           if isAuthenticated() && isEmailAllowed();
      allow create, update: if isAdmin();
      allow delete:         if isAdmin();
    }

    match /kpi_patents/{docId} {
      allow read:           if isAuthenticated() && isEmailAllowed();
      allow create, update: if isAdmin();
      allow delete:         if isAdmin();
    }
    // ── Phase 9: Roadmap Security Rules ─────────────────────────────────────
    //
    // Permission model source: Phase 4 planning doc.
    // All roadmap rules are ADDITIVE — no existing rule block is modified.
    // Reuses existing helpers: isAuthenticated(), isEmailAllowed(),
    //   isAdmin(), getEffectiveUid().
    //
    // Helper functions specific to roadmap:
    //   isRoadmapTaskAssignee(taskData) — true if effectiveUid is in task.assignedTo

    function isRoadmapTaskAssignee(taskData) {
      let uid      = getEffectiveUid();
      let assigned = taskData.get('assignedTo', []);
      return assigned is list && uid in assigned;
    }

    // ── roadmapNodes ─────────────────────────────────────────────────────────
    // Phase 4 §2–3:
    //   Read:   All whitelisted authenticated users can read all nodes
    //           (company-wide transparency — no filtering by assignedTo)
    //   Create: Admin only
    //   Update: Admin only — employees NEVER write directly to a node's structural
    //           or rollup fields; progress rollup is Cloud Function–owned (Phase 8)
    //   Delete: Admin only
    match /roadmapNodes/{nodeId} {
      allow read:   if isAuthenticated() && isEmailAllowed();
      allow create: if isAuthenticated() && isEmailAllowed() && isAdmin();
      allow update: if isAuthenticated() && isEmailAllowed() && isAdmin();
      allow delete: if isAuthenticated() && isEmailAllowed() && isAdmin();

      // ── tasks subcollection ───────────────────────────────────────────────
      // Phase 4 §4:
      //   Read:   Admin sees all. Assigned employee reads own tasks only.
      //   Create: Admin only — tasks are assigned, not self-created
      //   Update: Admin can change all fields.
      //           Assigned employee may only change:
      //             status | progress | completionNote | updatedBy | updatedAt
      //   Delete: Admin only
      match /tasks/{taskId} {
        allow read: if isAuthenticated() && isEmailAllowed() && (
          isAdmin() ||
          isRoadmapTaskAssignee(resource.data)
        );

        allow create: if isAuthenticated() && isEmailAllowed() && isAdmin();

        allow update: if isAuthenticated() && isEmailAllowed() && (
          isAdmin() ||
          (
            isRoadmapTaskAssignee(resource.data) &&
            request.resource.data.diff(resource.data)
              .affectedKeys()
              .hasOnly(['status', 'progress', 'completionNote', 'updatedBy', 'updatedAt'])
          )
        );

        allow delete: if isAuthenticated() && isEmailAllowed() && isAdmin();
      }

      // ── comments subcollection ────────────────────────────────────────────
      // Phase 4 §5:
      //   Read:          All whitelisted users (company-wide transparency)
      //   Create:        All whitelisted users — authorUid must equal effectiveUid
      //   Update/Delete: Own comment only (or admin)
      //   Constraints:   authorUid == effectiveUid (no impersonation)
      //                  text ≤ 2000 chars
      match /comments/{commentId} {
        allow read: if isAuthenticated() && isEmailAllowed();

        allow create: if isAuthenticated() && isEmailAllowed()
          && request.resource.data.get('authorUid', '') == getEffectiveUid()
          && request.resource.data.get('text', '').size() <= 2000;

        allow update: if isAuthenticated() && isEmailAllowed() && (
          isAdmin() ||
          resource.data.get('authorUid', '') == getEffectiveUid()
        );

        allow delete: if isAuthenticated() && isEmailAllowed() && (
          isAdmin() ||
          resource.data.get('authorUid', '') == getEffectiveUid()
        );
      }

      // ── history subcollection ─────────────────────────────────────────────
      // Phase 4 §6:
      //   Read:  All whitelisted users (audit trail transparency)
      //   Write: BLOCKED for all clients — Cloud Functions write via Admin SDK
      //          which bypasses these rules entirely. `allow write: if false`
      //          ensures no client (including admin) can tamper with history.
      match /history/{historyId} {
        allow read:  if isAuthenticated() && isEmailAllowed();
        allow write: if false;
      }

      // ── attachments subcollection ─────────────────────────────────────────
      // Phase 4 §7:
      //   Read:   All whitelisted users
      //   Create: All whitelisted users — uploadedBy must equal effectiveUid
      //           fileSize must be ≤ 10 MB (10,485,760 bytes)
      //   Update: Own attachment only (or admin)
      //   Delete: Own attachment only (uploadedBy == effectiveUid) or admin
      match /attachments/{attachmentId} {
        allow read: if isAuthenticated() && isEmailAllowed();

        allow create: if isAuthenticated() && isEmailAllowed()
          && request.resource.data.get('uploadedBy', '') == getEffectiveUid()
          && request.resource.data.get('fileSize', 0) <= 10485760;

        allow update: if isAuthenticated() && isEmailAllowed() && (
          isAdmin() ||
          resource.data.get('uploadedBy', '') == getEffectiveUid()
        );

        allow delete: if isAuthenticated() && isEmailAllowed() && (
          isAdmin() ||
          resource.data.get('uploadedBy', '') == getEffectiveUid()
        );
      }
    }

    // ── collectionGroup: tasks ────────────────────────────────────────────────
    // Phase 4 §8: Required for analytics queries (Phase 16) that use
    // collectionGroup('tasks') to span all tasks subcollections.
    //
    // Read: Admin sees all; employee sees only tasks where they are in assignedTo.
    //       This guard prevents the collectionGroup path from exposing tasks that
    //       the employee cannot see via the direct path rule above.
    //
    // NOTE: This rule COEXISTS with the root-level /tasks/{taskId} rule.
    //       Firestore evaluates each match path independently — no conflict.
    match /{path=**}/tasks/{taskId} {
      allow read: if isAuthenticated() && isEmailAllowed() && (
        isAdmin() ||
        (
          'assignedTo' in resource.data &&
          getEffectiveUid() in resource.data.assignedTo
        )
      );
    }

    // ── collectionGroup: history ──────────────────────────────────────────────
    // Phase 4 §8: Allows analytics/audit views to query across all history
    // subcollections. Clients can only read — write is blocked for all clients.
    match /{path=**}/history/{historyId} {
      allow read:  if isAuthenticated() && isEmailAllowed();
      allow write: if false;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // End Phase 9 roadmap rules
    // ─────────────────────────────────────────────────────────────────────────
  }
}
